# Server Configuration
PORT=3000
ENVIRONMENT=development
DEBUG=true

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=fintech_db
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=fintech-api

# Encryption Keys (32 bytes each for AES-256)
BVN_ENCRYPTION_KEY=32-byte-key-for-bvn-encryption!!
NIN_ENCRYPTION_KEY=32-byte-key-for-nin-encryption!!
AES_ENCRYPTION_KEY=32-byte-key-for-aes-encryption!!

# External APIs
NIP_BASE_URL=https://api.nip.com.ng/v1
NIP_API_KEY=your_nip_api_key
NIP_SECRET=your_nip_secret

BVN_BASE_URL=https://api.bvn.com.ng/v1
BVN_API_KEY=your_bvn_api_key

FACE_BASE_URL=https://api.face.com/v1
FACE_API_KEY=your_face_api_key

SMS_BASE_URL=https://api.sms.com.ng/v1
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=FintechApp

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_BURST=10

# RabbitMQ Queue
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QUEUE_EXCHANGE=fintech
QUEUE_NAME=transactions

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@fintech.com

# SMS Provider (termii, twilio, africanstalking)
SMS_PROVIDER=termii
SMS_API_KEY=your_sms_api_key
SMS_SECRET=your_sms_secret

# Cloudinary for file uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_COUNT=3

# Face Recognition
FACE_TOLERANCE=0.6
FACE_LIVENESS_THRESHOLD=0.8